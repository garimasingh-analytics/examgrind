# Copy this file to .env.local for local dev.
# In production (Vercel), set these in: Project Settings → Environment Variables.

# ─────────────────────────────────────────────────────────────
# Supabase — both values come from Supabase Dashboard → Settings → API
# NEXT_PUBLIC_* values are exposed to the browser. That's fine for the
# anon / publishable key (it's designed for that and is RLS-gated).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<...>

# Server-only. Used for any operation that needs to bypass RLS.
# Get it from Supabase Dashboard → Settings → API → service_role
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Anthropic — server-only. Used by /api/quiz/start and /api/quiz/analyze.
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-<...>

# Optional. If set, ops alerts (credit-balance-too-low, auth failures)
# are POSTed here as JSON { text: "..." }. Works with Slack incoming
# webhooks, Discord webhooks, or any endpoint that accepts JSON.
# Leave blank to log to Vercel logs only.
ALERT_WEBHOOK_URL=

# Comma-separated email allow-list for /admin access. Falls back to
# garimakalhansh@gmail.com if unset. Add new admins by listing them
# here in Vercel env vars and redeploying.
ADMIN_EMAILS=garimakalhansh@gmail.com

# ─────────────────────────────────────────────────────────────
# Razorpay — fill these in once your account is activated.
# Key ID is OK in the browser; Key Secret is server-only.
# Use test keys (rzp_test_…) until you flip to live (rzp_live_…).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Plan ID for the recurring ₹75/month subscription. Create one in the
# Razorpay Dashboard (Plans → New Plan, Monthly, ₹75, INR) and paste
# the resulting plan_… id here. Required for UPI Autopay flow.
RAZORPAY_PLAN_ID=

# Webhook secret. Set in Razorpay Dashboard → Webhooks. Paste the same
# string here. The /api/billing/webhook endpoint uses this to verify
# every event Razorpay sends us via HMAC-SHA256.
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Vercel preview: https://your-project-name-git-branch.vercel.app
# Vercel production: https://examgrind.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
